---
import Button from '../Button.astro';
---

<section class="hero">
  <div class="content">
    <p class="eyebrow">Linhares — ES · Desde 1996</p>
    <h1>Casual &amp; Street<br />pra viver a cidade</h1>
    <p class="lead">
      Do surf ao streetwear, do dia a dia ao look montado pra sair: a Landa
      veste Linhares há quase 30 anos.
    </p>
    <div class="actions">
      <Button href="/#estilos" variant="on-dark">Conheça os estilos</Button>
      <Button
        href="https://instagram.com/_landaloja"
        variant="on-dark"
      >
        Siga @_landaloja
      </Button>
    </div>
  </div>
  <div class="visual">
    <img
      src="/images/editorial-thesaint.jpg"
      alt="Look streetwear escuro em cenário editorial"
      loading="eager"
    />
  </div>
</section>

<style>
  .hero {
    background: var(--bg-dark);
    color: var(--fg-on-dark);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    min-height: 80vh;
  }

  .content {
    padding: var(--space-16) var(--container-pad);
    max-width: 36rem;
    margin-left: auto;
  }

  .eyebrow {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--accent-soft);
    margin-bottom: var(--space-4);
  }

  .lead {
    font-size: var(--text-lg);
    color: var(--paper-200);
    margin-top: var(--space-6);
  }

  .actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-8);
  }

  .visual {
    height: 100%;
    min-height: 24rem;
  }

  .visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 48rem) {
    .hero {
      grid-template-columns: 1fr;
    }

    .content {
      margin-left: 0;
    }
  }
</style>

---
import Button from '../Button.astro';
---

<!-- v2 (ref. Aramis, referencias/Capture.PNG): hero dividido — foto de um lado,
     tipografia display gigante do outro (minimalismo exagerado) -->
<section class="hero-split" aria-label="Landa — casual e street desde 1996">
  <div class="photo">
    <img
      src="/images/looks/look-trico-mostarda.jpg"
      alt="Tricô bordô e mostarda na porta da Landa"
      width="1200"
      height="1592"
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="statement">
    <p class="eyebrow">Linhares — ES · Desde 1996</p>
    <h1>Casual &amp; Street pra viver a cidade</h1>
    <p class="lead">
      Do surf ao streetwear, do dia a dia ao look montado pra sair.
    </p>
    <div class="actions">
      <Button href="/produtos">Ver produtos</Button>
      <a
        class="text-link"
        href="https://instagram.com/_landaloja"
        target="_blank"
        rel="noopener"
      >
        Siga @_landaloja →
      </a>
    </div>
  </div>
</section>

<style>
  /* Mobile-first: foto em cima, declaração embaixo */
  .hero-split {
    display: grid;
    grid-template-columns: 1fr;
  }

  .photo img {
    width: 100%;
    height: min(60dvh, 34rem);
    object-fit: cover;
    object-position: 50% 25%;
  }

  .statement {
    padding: var(--space-12) var(--container-pad);
  }

  .eyebrow {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--accent-deep);
  }

  .hero-split h1 {
    font-size: var(--text-display);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-top: var(--space-4);
    max-width: 12ch;
  }

  .lead {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    max-width: 40ch;
    margin-top: var(--space-6);
  }

  .actions {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    margin-top: var(--space-8);
  }

  .text-link {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--accent-deep);
  }

  @media (min-width: 48rem) {
    .hero-split {
      grid-template-columns: 1fr 1.2fr;
      align-items: stretch;
      border-bottom: 1px solid var(--line);
    }

    .photo img {
      height: 100%;
      min-height: min(78dvh, 46rem);
    }

    .statement {
      align-self: center;
      padding: var(--space-24) var(--space-12);
    }
  }
</style>

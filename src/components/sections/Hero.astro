---
import Button from '../Button.astro';
---

<section class="hero">
  <div class="content">
    <p class="eyebrow">Linhares — ES · Desde 1996</p>
    <h1>Casual &amp; Street<br />pra viver a cidade</h1>
    <p class="lead">
      Do surf ao streetwear, do dia a dia ao look montado pra sair: a Landa
      veste Linhares há quase 30 anos.
    </p>
    <div class="actions">
      <Button href="/#estilos" variant="on-dark">Conheça os estilos</Button>
      <Button
        href="https://instagram.com/_landaloja"
        variant="on-dark"
      >
        Siga @_landaloja
      </Button>
    </div>
  </div>
  <div class="visual">
    <img
      src="/images/editorial-thesaint.jpg"
      alt="Look streetwear escuro em cenário editorial"
      width="1200"
      height="1500"
      loading="eager"
      fetchpriority="high"
    />
  </div>
</section>

<style>
  /* Mobile-first: texto em cima, imagem contida embaixo */
  .hero {
    background: var(--bg-dark);
    color: var(--fg-on-dark);
    display: grid;
    grid-template-columns: 1fr;
  }

  .content {
    padding: var(--space-12) var(--container-pad);
    max-width: 36rem;
  }

  /* Entrada sutil, CSS puro (reduced-motion zera via global.css) */
  .content > * {
    animation: hero-in 700ms var(--ease-out) backwards;
  }

  .content > :nth-child(2) {
    animation-delay: 90ms;
  }

  .content > :nth-child(3) {
    animation-delay: 180ms;
  }

  .content > :nth-child(4) {
    animation-delay: 270ms;
  }

  @keyframes hero-in {
    from {
      opacity: 0;
      translate: 0 14px;
    }

    to {
      opacity: 1;
      translate: 0 0;
    }
  }

  .eyebrow {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--accent-soft);
    margin-bottom: var(--space-4);
  }

  .lead {
    font-size: var(--text-lg);
    color: var(--paper-200);
    margin-top: var(--space-6);
  }

  .actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-8);
  }

  /* No mobile a imagem vira faixa 4:3 pra não dominar a tela */
  .visual {
    aspect-ratio: 4 / 3;
  }

  .visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 48rem) {
    .hero {
      grid-template-columns: 1fr 1fr;
      align-items: center;
      min-height: 80vh;
    }

    .content {
      padding-block: var(--space-16);
      margin-left: auto;
    }

    .visual {
      aspect-ratio: auto;
      height: 100%;
      min-height: 24rem;
    }
  }
</style>

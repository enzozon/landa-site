---
import Container from '../Container.astro';
import Button from '../Button.astro';
---

<!-- Dobra fotográfica: a foto domina, o texto é anotação (macro 08, design.md) -->
<section class="hero-photo" aria-label="Landa — casual e street desde 1996">
  <img
    class="bleed"
    src="/images/editorial-thesaint.jpg"
    alt="Look streetwear escuro em cenário editorial"
    width="1200"
    height="1500"
    loading="eager"
    fetchpriority="high"
  />
  <div class="caption">
    <p class="place">Linhares — ES · desde 1996.</p>
    <a class="caption-link" href="/produtos">Ver o que chegou →</a>
  </div>
</section>

<section class="hero-lede">
  <Container>
    <h1>Casual &amp; Street pra viver a cidade</h1>
    <p class="lead">
      Do surf ao streetwear, do dia a dia ao look montado pra sair: a Landa
      veste Linhares há quase 30 anos.
    </p>
    <div class="actions">
      <Button href="/produtos">Ver produtos</Button>
      <a
        class="text-link"
        href="https://instagram.com/_landaloja"
        target="_blank"
        rel="noopener"
      >
        Siga @_landaloja →
      </a>
    </div>
  </Container>
</section>

<style>
  .hero-photo {
    position: relative;
    height: min(72dvh, 42rem);
  }

  .hero-photo .bleed {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 30%;
  }

  /* Scrim só na base, pra legenda ler sobre qualquer foto */
  .caption {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: var(--space-16) var(--container-pad) var(--space-6);
    background: linear-gradient(transparent, var(--scrim-ink));
    color: var(--fg-on-dark);
  }

  .place {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  .caption-link {
    display: inline-block;
    margin-top: var(--space-2);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--fg-on-dark);
    border-bottom: 2px solid var(--accent-soft);
    padding-bottom: 2px;
  }

  .caption-link:hover {
    color: var(--accent-soft);
  }

  /* Faixa estreita de texto: a declaração vem depois da foto */
  .hero-lede {
    padding-block: var(--section-y) 0;
  }

  .hero-lede h1 {
    max-width: 16ch;
  }

  .lead {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    max-width: 44ch;
    margin-top: var(--space-6);
  }

  .actions {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    margin-top: var(--space-8);
  }

  .text-link {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--accent-deep);
  }

  @media (min-width: 48rem) {
    .hero-photo {
      height: min(82dvh, 48rem);
    }

    .caption {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: var(--space-4);
    }

    .caption-link {
      margin-top: 0;
    }
  }
</style>

---
import Container from '../Container.astro';
import SectionHeading from '../SectionHeading.astro';

const styles = [
  {
    image: '/images/products/camiseta-vans.jpg',
    title: 'Camisetas',
    href: '/produtos#camisetas',
  },
  {
    image: '/images/looks/look-camisa-bege.jpg',
    title: 'Camisas',
    href: '/produtos#camisas',
  },
  {
    image: '/images/looks/look-trico-calca.jpg',
    title: 'Tricô & Moletom',
    href: '/produtos#trico-moletom',
  },
  {
    image: '/images/looks/look-terno-roxo.jpg',
    title: 'Feminino',
    href: '/produtos#feminino',
  },
  {
    image: '/images/products/tenis-nb-par.jpg',
    title: 'Calçados',
    href: '/produtos#calcados',
  },
  {
    image: '/images/products/bones-nb.jpg',
    title: 'Acessórios',
    href: '/produtos#acessorios',
  },
];
---

<!-- v2 (ref. Ellus, referencias/Capture5.PNG): tiles com overlay duotone da
     marca e rótulo grande sobre a foto -->
<section id="estilos" class="style-grid-section">
  <Container>
    <div data-reveal>
      <SectionHeading eyebrow="Pra todo estilo" title="Do surf ao street" />
    </div>
    <ul class="grid">
      {
        styles.map((style, index) => (
          <li class="card" data-reveal style={`--reveal-delay: ${index * 60}ms`}>
            <a href={style.href}>
              <div class="frame">
                <img
                  src={style.image}
                  alt=""
                  width="1200"
                  height="1500"
                  loading="lazy"
                />
                <div class="overlay">
                  <h3>{style.title}</h3>
                  <span class="more">Confira a seleção</span>
                </div>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </Container>
</section>

<style>
  .style-grid-section {
    padding-top: var(--section-y);
  }

  /* Mobile-first: 1 coluna, cresce com a tela */
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .frame {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--bg-alt);
  }

  .frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms var(--ease-out);
  }

  /* Duotone bordô: a foto lê como peça única da marca */
  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    text-align: center;
    padding: var(--space-4);
    background: linear-gradient(
      rgb(81 32 28 / 0.3),
      rgb(81 32 28 / 0.55)
    );
    color: var(--white);
  }

  .overlay h3 {
    font-size: var(--text-2xl);
    letter-spacing: var(--tracking-wide);
  }

  .more {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    border: 1px solid var(--white);
    padding: var(--space-2) var(--space-4);
    transition:
      background var(--transition-fast),
      color var(--transition-fast);
  }

  .card a:hover .frame img,
  .card a:focus-visible .frame img {
    transform: scale(1.04);
  }

  .card a:hover .more,
  .card a:focus-visible .more {
    background: var(--white);
    color: var(--accent-deep);
  }

  @media (min-width: 40rem) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 60rem) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }

    /* Ritmo de vitrine (ref. Ellus): primeiro tile da fileira maior */
    .card:nth-child(6n + 1),
    .card:nth-child(6n + 6) {
      grid-column: span 2;
    }

    .card:nth-child(6n + 1) .frame,
    .card:nth-child(6n + 6) .frame {
      aspect-ratio: 8 / 5;
    }
  }
</style>

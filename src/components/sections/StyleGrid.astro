---
import Container from '../Container.astro';
import SectionHeading from '../SectionHeading.astro';

const styles = [
  {
    image: '/images/products/camiseta-vans.jpg',
    title: 'Camisetas',
    description: 'Básicas e estampadas pra rodar o dia inteiro.',
    href: '/produtos#camisetas',
  },
  {
    image: '/images/looks/look-camisa-bege.jpg',
    title: 'Camisas',
    description: 'Flanelas, xadrezes e bordadas pro look mais montado.',
    href: '/produtos#camisas',
  },
  {
    image: '/images/looks/look-trico-calca.jpg',
    title: 'Tricô & Moletom',
    description: 'Malharia pesada pra ficar bem em qualquer rolê.',
    href: '/produtos#trico-moletom',
  },
  {
    image: '/images/looks/look-terno-roxo.jpg',
    title: 'Feminino',
    description: 'Vestidos, conjuntos e alfaiataria escolhidos a dedo.',
    href: '/produtos#feminino',
  },
  {
    image: '/images/products/tenis-nb-par.jpg',
    title: 'Calçados',
    description: 'Tênis pra completar o visual, do skate à rua.',
    href: '/produtos#calcados',
  },
  {
    image: '/images/products/bones-nb.jpg',
    title: 'Acessórios',
    description: 'Bonés, óculos e relógios que fecham o look.',
    href: '/produtos#acessorios',
  },
];
---

<section id="estilos" class="style-grid-section">
  <Container>
    <div data-reveal>
      <SectionHeading eyebrow="Pra todo estilo" title="Do surf ao street" />
    </div>
    <ul class="grid">
      {
        styles.map((style, index) => (
          <li class="card" data-reveal style={`--reveal-delay: ${index * 60}ms`}>
            <a href={style.href}>
              <div class="frame">
                <img
                  src={style.image}
                  alt={style.title}
                  width="1200"
                  height="1500"
                  loading="lazy"
                />
              </div>
              <h3>{style.title}</h3>
              <p>{style.description}</p>
              <span class="more" aria-hidden="true">Ver peças →</span>
            </a>
          </li>
        ))
      }
    </ul>
  </Container>
</section>

<style>
  .style-grid-section {
    padding-top: var(--section-y);
  }

  /* Mobile-first: 1 coluna, cresce com a tela */
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8) var(--space-6);
  }

  .frame {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--radius-md);
    background: var(--bg-alt);
    margin-bottom: var(--space-4);
  }

  .frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms var(--ease-out);
  }

  .card a:hover .frame img,
  .card a:focus-visible .frame img {
    transform: scale(1.04);
  }

  .card h3 {
    font-size: var(--text-lg);
  }

  .card p {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    margin-top: var(--space-1);
  }

  .more {
    display: inline-block;
    margin-top: var(--space-2);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--accent-deep);
    transition: translate var(--transition-fast);
  }

  .card a:hover .more,
  .card a:focus-visible .more {
    translate: 4px 0;
  }

  @media (min-width: 40rem) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 60rem) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

---
import Container from '../Container.astro';
import SectionHeading from '../SectionHeading.astro';
import { products } from '../../data/products';

// v2 (ref. Planner, referencias/Capture9.PNG): vitrine de destaques com preço
const DESTAQUES = [
  'camiseta-off-the-wall',
  'trico-mescla-bordo',
  'tenis-fresh-foam',
  'vestido-cetim-off-white',
];

const destaques = DESTAQUES.map((slug) =>
  products.find((product) => product.slug === slug)
).filter((product) => product !== undefined);

const formatPrice = (price: number) =>
  price.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
---

<section class="mais-vendidos">
  <Container>
    <div data-reveal>
      <SectionHeading eyebrow="Destaques" title="Mais pedidos" />
    </div>
    <ul class="grid">
      {
        destaques.map((product, index) => (
          <li data-reveal style={`--reveal-delay: ${index * 60}ms`}>
            <a class="card" href={`/produto/${product.slug}`}>
              <div class="frame">
                <img
                  src={product.image}
                  alt={product.name}
                  width="1200"
                  height="1500"
                  loading="lazy"
                />
              </div>
              <h3>{product.name}</h3>
              <p class="price">
                {product.price === null
                  ? 'Preço sob consulta'
                  : formatPrice(product.price)}
              </p>
              <span class="cta">Comprar agora</span>
            </a>
          </li>
        ))
      }
    </ul>
  </Container>
</section>

<style>
  .mais-vendidos {
    padding-top: var(--section-y);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8) var(--space-4);
  }

  .frame {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--bg-alt);
    margin-bottom: var(--space-4);
  }

  .frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms var(--ease-out);
  }

  .card:hover .frame img,
  .card:focus-visible .frame img {
    transform: scale(1.04);
  }

  .card h3 {
    font-size: var(--text-base);
  }

  .price {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    margin-top: var(--space-1);
  }

  /* Botão de vitrine (ref. Planner): barra escura de largura total */
  .cta {
    display: block;
    margin-top: var(--space-3);
    padding: var(--space-3) var(--space-4);
    text-align: center;
    background: var(--ink-900);
    color: var(--fg-on-dark);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    transition: background var(--transition-fast);
  }

  .card:hover .cta,
  .card:focus-visible .cta {
    background: var(--accent-deep);
  }

  @media (min-width: 60rem) {
    .grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-8) var(--space-6);
    }
  }
</style>

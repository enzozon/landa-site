---
import type { Product } from '../data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<article class="product-card" data-reveal>
  <a href={`/produto/${product.slug}`}>
    <div class="frame">
      <img src={product.image} alt={product.name} loading="lazy" />
      <span class="cta">Ver detalhes</span>
    </div>
    {product.brand && <p class="brand">{product.brand}</p>}
    <h3>{product.name}</h3>
  </a>
</article>

<style>
  .frame {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--radius-md);
    background: var(--bg-alt);
    margin-bottom: var(--space-3);
  }

  .frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }

  .product-card:hover .frame img {
    transform: scale(1.04);
  }

  .cta {
    position: absolute;
    inset-inline: var(--space-3);
    bottom: var(--space-3);
    text-align: center;
    padding: var(--space-2);
    background: rgb(20 22 24 / 0.85);
    color: var(--fg-on-dark);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    border-radius: var(--radius-sm);
    opacity: 0;
    translate: 0 6px;
    transition:
      opacity var(--transition-fast),
      translate var(--transition-fast);
  }

  .product-card:hover .cta,
  .product-card:focus-within .cta {
    opacity: 1;
    translate: 0 0;
  }

  .brand {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--accent);
  }

  h3 {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    text-transform: none;
    line-height: var(--leading-snug);
    margin-top: var(--space-1);
  }

  @media (prefers-reduced-motion: reduce) {
    .cta {
      opacity: 1;
      translate: 0 0;
    }
  }
</style>

---
interface Props {
  href: string;
  variant?: 'solid' | 'outline' | 'on-dark';
  target?: string;
  rel?: string;
}

const { href, variant = 'solid', target, rel } = Astro.props;
// Links externos nunca ficam sem noopener, mesmo se o chamador esquecer
const safeRel = rel ?? (target === '_blank' ? 'noopener' : undefined);
---

<a href={href} target={target} rel={safeRel} class:list={['button', variant]}>
  <slot />
</a>

<style>
  .button {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    border: 2px solid var(--fg);
    border-radius: var(--radius-sm);
    transition:
      background var(--transition-fast),
      color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .solid {
    background: var(--fg);
    color: var(--bg);
  }

  .solid:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--white);
  }

  .outline {
    background: transparent;
    color: var(--fg);
  }

  .outline:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .on-dark {
    background: transparent;
    border-color: var(--fg-on-dark);
    color: var(--fg-on-dark);
  }

  .on-dark:hover {
    background: var(--fg-on-dark);
    color: var(--bg-dark);
  }
</style>

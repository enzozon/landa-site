---
import Base from '../../layouts/Base.astro';
import Container from '../../components/Container.astro';
import Button from '../../components/Button.astro';
import { categories, products, type Product } from '../../data/products';
import { store, whatsappUrl } from '../../data/store';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const category = categories.find((c) => c.id === product.category);
const images = [product.image, ...(product.gallery ?? [])];
const priceLabel =
  product.price === null
    ? null
    : product.price.toLocaleString('pt-BR', {
        style: 'currency',
        currency: 'BRL',
      });
const message = `Oi! Vi o site e me interessei: ${product.name}`;
---

<Base
  title={`${product.name} — Landa | Linhares-ES`}
  description={`${product.name} na Landa, em Linhares-ES. Consulte tamanho e preço pelo WhatsApp.`}
  ogImage={product.image}
>
  <Container>
    <nav class="breadcrumb" aria-label="Você está em">
      <a href="/produtos">Produtos</a>
      {
        category && (
          <>
            <span aria-hidden="true">/</span>
            <a href={`/produtos#${category.id}`}>{category.label}</a>
          </>
        )
      }
      <span aria-hidden="true">/</span>
      <span aria-current="page">{product.name}</span>
    </nav>

    <article class="product">
      <div class="media">
        {
          images.map((src, index) => (
            <img
              src={src}
              alt={
                index === 0 ? product.name : `${product.name} — detalhe ${index}`
              }
              width="1200"
              height="1600"
              loading={index === 0 ? 'eager' : 'lazy'}
              fetchpriority={index === 0 ? 'high' : undefined}
            />
          ))
        }
      </div>

      <div class="info">
        {product.brand && <p class="brand">{product.brand}</p>}
        <h1>{product.name}</h1>

        {
          priceLabel ? (
            <p class="price">{priceLabel}</p>
          ) : (
            <p class="price is-placeholder">
              <span aria-hidden="true">R$ —</span>
              <span class="price-note">Preço sob consulta</span>
            </p>
          )
        }

        <fieldset class="sizes">
          <legend>Tamanho</legend>
          <div class="size-options">
            {
              product.sizes.map((size) => (
                <label class="size">
                  <input type="radio" name="tamanho" value={size} />
                  <span>{size}</span>
                </label>
              ))
            }
          </div>
        </fieldset>

        <div class="actions">
          <a
            id="whats-cta"
            class="whats"
            href={whatsappUrl(`${message}. Ainda tem?`)}
            data-message={message}
            target="_blank"
            rel="noopener"
          >
            Consultar no WhatsApp
          </a>
          <Button
            href={store.instagramUrl}
            variant="outline"
            target="_blank"
            rel="noopener"
          >
            Chama no Instagram
          </Button>
        </div>

        <p class="note">
          Retira na loja: {store.addressStreet} — {store.addressDistrict}.
          Chega pra provar antes de levar.
        </p>
      </div>
    </article>
  </Container>
</Base>

<script>
  // Escolher um tamanho atualiza a mensagem do link do WhatsApp.
  import { whatsappUrl } from '../../data/store';

  const cta = document.getElementById('whats-cta');
  const message = cta?.getAttribute('data-message') ?? '';

  document
    .querySelectorAll<HTMLInputElement>('input[name="tamanho"]')
    .forEach((radio) => {
      radio.addEventListener('change', () => {
        if (cta instanceof HTMLAnchorElement && radio.checked) {
          cta.href = whatsappUrl(
            `${message}, tamanho ${radio.value}. Ainda tem?`
          );
        }
      });
    });
</script>

<style>
  .breadcrumb {
    display: flex;
    gap: var(--space-2);
    padding-block: var(--space-6);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--fg-muted);
  }

  .breadcrumb a:hover {
    color: var(--accent-deep);
  }

  /* Mobile-first: foto em cima, informações embaixo */
  .product {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  .media {
    display: grid;
    gap: var(--space-4);
  }

  .media img {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: var(--radius-md);
    background: var(--bg-alt);
  }

  .brand {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--accent);
  }

  h1 {
    font-size: var(--text-3xl);
    margin-top: var(--space-1);
  }

  .price {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 900;
    margin-top: var(--space-4);
  }

  .price.is-placeholder {
    color: var(--fg-muted);
  }

  .price-note {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--fg-muted);
    margin-top: var(--space-1);
  }

  .sizes {
    border: 0;
    padding: 0;
    margin-top: var(--space-8);
  }

  .sizes legend {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-3);
  }

  .size-options {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .size input {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .size span {
    display: inline-block;
    min-width: 3rem;
    padding: var(--space-2) var(--space-3);
    text-align: center;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    /* fg-muted em vez de --line: borda precisa de contraste >= 3:1 (WCAG 1.4.11) */
    border: 1px solid var(--fg-muted);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition:
      background var(--transition-fast),
      color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .size span:hover {
    border-color: var(--fg);
  }

  .size input:checked + span {
    background: var(--fg);
    border-color: var(--fg);
    color: var(--bg);
  }

  .size input:focus-visible + span {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .whats {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    background: var(--accent-deep);
    border: 2px solid var(--accent-deep);
    border-radius: var(--radius-sm);
    color: var(--white);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  .whats:hover {
    background: var(--accent);
    border-color: var(--accent);
  }

  .note {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    margin-top: var(--space-6);
  }

  @media (min-width: 48rem) {
    .product {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
    }

    .info {
      position: sticky;
      top: calc(var(--header-h) + var(--space-6));
      align-self: start;
    }
  }
</style>

---
import '@fontsource-variable/inter';
import '@fontsource-variable/archivo';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { store } from '../data/store';

interface Props {
  title: string;
  description?: string;
  /** Imagem de preview ao compartilhar (WhatsApp/Instagram); caminho absoluto local */
  ogImage?: string;
}

const {
  title,
  description = 'Landa — moda casual e street em Linhares-ES desde 1996.',
  ogImage = '/images/og.jpg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);

// Dados estruturados da loja física (Google: horário, endereço, telefone)
const schema = {
  '@context': 'https://schema.org',
  '@type': 'ClothingStore',
  name: store.name,
  description:
    'Loja de moda casual e street em Linhares-ES desde 1996. Camisetas, camisas, tricô, moda feminina, calçados e acessórios.',
  url: Astro.site?.href,
  image: ogImageUrl.href,
  telephone: store.phoneE164,
  address: {
    '@type': 'PostalAddress',
    streetAddress: store.addressStreet,
    addressLocality: 'Linhares',
    addressRegion: 'ES',
    addressCountry: 'BR',
  },
  openingHoursSpecification: store.schemaHours.map((slot) => ({
    '@type': 'OpeningHoursSpecification',
    ...slot,
  })),
  sameAs: [store.instagramUrl],
  foundingDate: '1996',
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/images/logo.jpg" type="image/jpeg" />
    <link rel="canonical" href={canonical.href} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Landa" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      // Scroll-reveal: marca o <html> como "com JS" e revela [data-reveal]
      // conforme entra na viewport. Sem JS ou com reduced-motion, o CSS
      // garante que tudo fica visível.
      document.documentElement.classList.add('js');

      const revealTargets = document.querySelectorAll('[data-reveal]');
      const prefersReducedMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches;

      if (prefersReducedMotion || !('IntersectionObserver' in window)) {
        revealTargets.forEach((el) => el.classList.add('is-visible'));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px' }
        );
        revealTargets.forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
